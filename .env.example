# ── SafeRoute environment variables ──────────────────────────────
# Copy this file to ".env" and fill in your own values.
# In Vite, only variables prefixed with VITE_ are exposed to the app.

# Supabase (REQUIRED) — from your project's Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Google Maps (OPTIONAL / legacy) — NOT required.
# The app uses free OpenStreetMap + Leaflet + OSRM + Open-Meteo instead.
# Leave blank unless you re-introduce a Google Maps component.
VITE_GOOGLE_MAPS_API_KEY=
